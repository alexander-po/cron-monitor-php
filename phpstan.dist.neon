parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        # Symfony DI configurator scripts use the global `service()`,
        # `tagged_iterator()`, etc. helpers that exist only after the DI
        # closure binding is applied at compile time. PHPStan sees them as
        # free-standing functions; analysing the file produces only false
        # positives. The runtime contract is exercised by the Symfony
        # functional tests in the host application instead.
        - src/Bridge/Symfony/Resources/config/services.php
    treatPhpDocTypesAsCertain: false
    # `app()` is a Laravel-side global helper available everywhere inside a
    # booted Laravel application (defined in illuminate/foundation, which we
    # do not pull in as a dev-dep). PHPStan picks up a minimal shim from
    # `tests/bootstrap.php` so analyses of both `src/` and `tests/` resolve
    # the function without per-file ignore rules.
